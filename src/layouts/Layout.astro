---
import {
  defaultDescription,
  defaultTitle,
  getFaqStructuredData,
  getBaseStructuredData,
  resolveMetaImage,
  siteName,
  siteUrl
} from '../utils/seo';
import type { FaqItem } from '../utils/seo';
import WebMcpProvider from '../components/WebMcpProvider.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  ogType?: 'website' | 'article';
  publishedTime?: string;
  author?: string;
  noIndex?: boolean;
  faqItems?: FaqItem[];
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title = defaultTitle,
  description = defaultDescription,
  image,
  ogType = 'website',
  publishedTime,
  author = 'Dr. Jelena Djurovic',
  noIndex = false,
  faqItems = [],
  structuredData: customStructuredData
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? siteUrl).toString();
const socialImage = resolveMetaImage(image);

const customStructuredDataItems = Array.isArray(customStructuredData)
  ? customStructuredData
  : customStructuredData
    ? [customStructuredData]
    : [];

const structuredData = [
  getBaseStructuredData(description),
  ogType === 'article'
    ? {
        '@context': 'https://schema.org',
        '@type': 'Article',
        headline: title,
        description,
        image: socialImage,
        author: {
          '@type': 'Person',
          name: author
        },
        publisher: {
          '@type': 'Organization',
          name: siteName,
          logo: {
            '@type': 'ImageObject',
            url: resolveMetaImage('/images/logo.png')
          }
        },
        datePublished: publishedTime,
        mainEntityOfPage: canonicalUrl
      }
    : null,
  faqItems.length > 0 ? getFaqStructuredData(faqItems) : null,
  ...customStructuredDataItems
].filter(Boolean);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/images/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
      as="style"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
        rel="stylesheet"
      />
    </noscript>
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noIndex ? 'noindex, nofollow' : 'index, follow'} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="theme-color" content="#2f594f" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="google-site-verification" content="ctEdt7ugcXaqhwULL18mjtGCnqqwiWHvB7cQrW-o190" />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-N367CP9MSE"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-N367CP9MSE');
    </script>
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {author && ogType === 'article' && <meta property="article:author" content={author} />}
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body class="font-inter bg-white antialiased">
    <slot />
    <WebMcpProvider />
  </body>
</html>
