---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import FaqSection from '../components/FaqSection.astro';
import LocalServiceArea from '../components/LocalServiceArea.astro';
import TopicHero from '../components/TopicHero.astro';
import TopicOverviewSection from '../components/TopicOverviewSection.astro';
import TopicProcessSection from '../components/TopicProcessSection.astro';
import { getServiceStructuredData } from '../utils/seo';

const phases = [
  {
    title: "Pre-Divorce Counseling",
    desc: "Support while sorting through fear, uncertainty, grief, anger, boundary questions, and the practical emotional impact of deciding what comes next."
  },
  {
    title: "Post-Divorce Counseling",
    desc: "Help with recovery, co-parenting stress, identity rebuilding, loneliness, dating concerns, trust issues, and adjusting to a very different life structure."
  }
];

const relatedLinks = [
  {
    href: '/therapy',
    title: 'Therapy',
    desc: 'Explore broader support for anxiety, depression, grief, trauma, and relationship stress.'
  },
  {
    href: '/self-compassion-therapy',
    title: 'Self-Compassion Therapy',
    desc: 'Helpful when divorce or separation has intensified shame, self-blame, or harsh self-judgment.'
  },
  {
    href: '/contact',
    title: 'Book a Consultation',
    desc: 'Reach out to ask about divorce counseling in person or via telehealth.'
  }
];

const signals = ['In-person in Schaumburg', 'Telehealth across Illinois', 'Support before, during, and after separation'];

const careStyle = [
  {
    title: 'Grounded and calm',
    desc: 'Helpful when everything feels emotionally loud, urgent, or hard to sort through.'
  },
  {
    title: 'Emotionally direct',
    desc: 'Makes space for grief, anger, relief, and uncertainty without forcing one clean narrative.'
  },
  {
    title: 'Transition-focused',
    desc: 'Useful when co-parenting, identity, loneliness, and practical decisions are all in motion at once.'
  }
];

const overviewParagraphs = [
  "Divorce can bring grief, relief, fear, anger, confusion, and practical stress all at once. Even when separation is the right decision, it can still be emotionally disorienting.",
  'Therapy offers a structured, supportive space to think clearly, regulate emotions, and move through this transition with more steadiness and less isolation.',
  'For clients in and around Schaumburg, in-person care is available locally, and telehealth makes divorce counseling accessible across Illinois.'
];

const processParagraphs = [
  'Divorce counseling may focus on decision-making, grief, communication boundaries, co-parenting stress, emotional recovery, rebuilding confidence, and understanding patterns that you do not want to repeat.',
  'It can also be helpful when separation has triggered anxiety, depression, sleep disruption, body stress, or a painful collapse in self-worth.'
];

const processSteps = [
  {
    title: 'Create steadiness during uncertainty',
    desc: 'Make room for competing emotions while getting clearer about what you need and what comes next.'
  },
  {
    title: 'Protect energy and boundaries',
    desc: 'Work on communication, co-parenting, and emotional limits when conflict or contact feels draining.'
  },
  {
    title: 'Rebuild after the rupture',
    desc: 'Support recovery, self-trust, and a more stable sense of identity in the next chapter.'
  }
];

const pageDescription =
  'Divorce counseling in Schaumburg, IL with telehealth across Illinois for support before divorce, after divorce, co-parenting stress, grief, relationship loss, and major life transitions.';

const faqItems = [
  {
    question: 'Can divorce counseling help before a divorce is final?',
    answer:
      'Yes. Divorce counseling can be helpful during the decision-making phase, during separation, and after divorce when grief, anger, confusion, or practical stress are still very active.'
  },
  {
    question: 'Do you offer divorce counseling in Schaumburg, IL and online?',
    answer:
      'Yes. Sessions are available in person in Schaumburg and through telehealth for clients across Illinois.'
  },
  {
    question: 'Is divorce counseling only for people who are sure they want to separate?',
    answer:
      'No. Some clients come in because they are trying to think clearly about what they want, while others come in after separation or divorce to process the emotional aftermath and rebuild stability.'
  }
];

const serviceStructuredData = getServiceStructuredData({
  name: 'Divorce Counseling',
  description: pageDescription,
  path: '/divorce-counseling/',
  serviceType: 'Divorce Counseling'
});
---

<Layout
  title="Divorce Counseling in Schaumburg, IL"
  description={pageDescription}
  faqItems={faqItems}
  structuredData={serviceStructuredData}
>
  <Navbar />
  <TopicHero
    title="Divorce Counseling"
    accent="for one of life's hardest transitions"
    description="Therapy support before divorce, during separation, and after divorce for grief, overwhelm, co-parenting stress, identity shifts, and rebuilding stability."
    imageAlt="Warm and calm therapy office in Schaumburg"
    imageSrc="/images/divorce-counseling.jpg"
    fitText="support that helps you think clearly while carrying grief, anger, fear, and change all at once"
    signals={signals}
    careStyle={careStyle}
  />

  <TopicOverviewSection
    eyebrow="Life Transition Support"
    title="A structured space when everything feels emotionally mixed"
    paragraphs={overviewParagraphs}
    cards={phases}
  />

  <TopicProcessSection
    eyebrow="What Counseling Can Hold"
    title="Common areas of focus before and after separation"
    paragraphs={processParagraphs}
    steps={processSteps}
  />

  <LocalServiceArea serviceName="Divorce Counseling" />

  <FaqSection
    faqs={faqItems}
    intro="Common questions about timing, fit, and access for divorce-related support."
  />

  <section class="py-16 xl:py-24 bg-white relative">
    <div class="max-w-[1200px] mx-auto px-5 md:px-10 xl:px-24">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2 class="text-3xl md:text-5xl font-bold text-[#1a1a1a] mb-6">Related Pages</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {relatedLinks.map((link) => (
          <a href={link.href} class="bg-[#fcfbf9] p-8 rounded-3xl border border-gray-100 hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            <h3 class="text-xl font-bold text-[#1a1a1a] mb-3">{link.title}</h3>
            <p class="text-gray-600 leading-relaxed">{link.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 md:py-28 bg-[#2f594f] relative overflow-hidden">
    <div class="max-w-[1000px] mx-auto px-5 md:px-10 text-center relative z-10">
      <h2 class="text-3xl md:text-5xl lg:text-6xl font-extrabold text-white mb-6 md:mb-8 tracking-tight">Support can make this transition less overwhelming</h2>
      <a href="/contact" class="inline-flex items-center justify-center px-8 md:px-12 py-4 bg-[#fcc13e] text-[#1a1a1a] text-lg font-bold rounded-full hover:bg-white hover:text-[#2f594f] hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
        Contact Us
      </a>
    </div>
  </section>

  <Footer />
</Layout>
