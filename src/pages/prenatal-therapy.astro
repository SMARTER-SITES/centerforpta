---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import FaqSection from '../components/FaqSection.astro';
import LocalServiceArea from '../components/LocalServiceArea.astro';
import TopicHero from '../components/TopicHero.astro';
import TopicOverviewSection from '../components/TopicOverviewSection.astro';
import TopicProcessSection from '../components/TopicProcessSection.astro';
import { getServiceStructuredData } from '../utils/seo';

const supportAreas = [
  "Pregnancy-related anxiety and uncertainty",
  "Medical stress and decision fatigue",
  "Fear around labor, parenting, or major life change",
  "Relationship strain during pregnancy",
  "History of anxiety, depression, trauma, or reproductive loss",
  "Identity changes and emotional adjustment to pregnancy"
];

const relatedLinks = [
  {
    href: '/postpartum-therapy',
    title: 'Postpartum Therapy',
    desc: 'Support after birth for mood changes, overwhelm, and postnatal adjustment.'
  },
  {
    href: '/womens-mental-health-therapy',
    title: "Women's Mental Health Therapy",
    desc: 'Broader support for reproductive challenges, life-stage stress, and body image concerns.'
  },
  {
    href: '/contact',
    title: 'Book a Consultation',
    desc: 'Ask about prenatal therapy in person or through telehealth across Illinois.'
  }
];

const signals = ['In-person in Schaumburg', 'Telehealth across Illinois', 'Support during pregnancy and reproductive stress'];

const careStyle = [
  {
    title: 'Warm and stabilizing',
    desc: 'Helpful when pregnancy feels emotionally vulnerable, uncertain, or more intense than expected.'
  },
  {
    title: 'Practical and emotionally aware',
    desc: 'Makes room for both feelings and the real-life demands of medical decisions, relationships, and change.'
  },
  {
    title: 'Built for layered history',
    desc: 'Especially relevant when pregnancy overlaps with anxiety, trauma, infertility, or reproductive loss.'
  }
];

const overviewParagraphs = [
  'Pregnancy is often described as a joyful period, but many people also experience fear, grief, irritability, pressure, uncertainty, and emotional vulnerability. That does not mean you are doing anything wrong. It means you are living through a major transition.',
  'Prenatal therapy can help you process what is coming up emotionally while giving you steadier tools for coping, communication, and self-care.',
  'If you are looking for prenatal therapy near Schaumburg, sessions can happen in person there or online anywhere in Illinois.'
];

const overviewCards = supportAreas.map((area) => ({
  title: area,
  desc: 'A common way pregnancy can bring more emotional pressure, uncertainty, or vulnerability into daily life.'
}));

const processParagraphs = [
  'Prenatal therapy may be particularly helpful if pregnancy is happening alongside infertility history, reproductive loss, high stress, trauma history, prior depression or anxiety, or significant family or relationship strain.',
  'The goal is not to force a certain emotional experience, but to help you move through pregnancy with more support, clarity, and internal steadiness.'
];

const processSteps = [
  {
    title: 'Name what feels hard',
    desc: 'Put words to anxiety, medical stress, grief, or uncertainty instead of carrying it silently.'
  },
  {
    title: 'Support the nervous system',
    desc: 'Build steadier coping tools for decision fatigue, fear, irritability, and emotional overload.'
  },
  {
    title: 'Prepare for what is ahead',
    desc: 'Strengthen communication, self-care, and emotional readiness for the next stage of pregnancy and birth.'
  }
];

const pageDescription =
  'Prenatal therapy in Schaumburg, IL with telehealth across Illinois for pregnancy anxiety, stress, reproductive loss history, relationship changes, medical decision fatigue, and emotional support during pregnancy.';

const faqItems = [
  {
    question: 'What is prenatal therapy helpful for?',
    answer:
      'Prenatal therapy can help with pregnancy anxiety, medical stress, fear around labor or parenting, reproductive loss history, relationship strain, and the emotional adjustment that can happen during pregnancy.'
  },
  {
    question: 'Do you offer prenatal therapy in Schaumburg, IL and online in Illinois?',
    answer:
      'Yes. Prenatal therapy is available in person in Schaumburg and by telehealth for clients anywhere in Illinois.'
  },
  {
    question: 'Can prenatal therapy help if I already have a history of anxiety or trauma?',
    answer:
      'Yes. Prenatal therapy may be especially helpful when pregnancy overlaps with prior anxiety, depression, trauma, infertility stress, or reproductive loss.'
  }
];

const serviceStructuredData = getServiceStructuredData({
  name: 'Prenatal Therapy',
  description: pageDescription,
  path: '/prenatal-therapy/',
  serviceType: 'Prenatal Therapy'
});
---

<Layout
  title="Prenatal Therapy in Schaumburg, IL"
  description={pageDescription}
  faqItems={faqItems}
  structuredData={serviceStructuredData}
>
  <Navbar />
  <TopicHero
    title="Prenatal Therapy"
    accent="when pregnancy brings more than joy"
    description="Emotional support during pregnancy for anxiety, overwhelm, medical stress, relationship changes, and the many adjustments that can happen before birth."
    imageAlt="Quiet therapy office for prenatal support"
    imageSrc="/images/prenatal-therapy.jpg"
    fitText="support during pregnancy when fear, pressure, grief, or uncertainty need more room and steadiness"
    signals={signals}
    careStyle={careStyle}
  />

  <TopicOverviewSection
    eyebrow="Pregnancy Support"
    title="Pregnancy can be meaningful and hard at the same time"
    paragraphs={overviewParagraphs}
    cards={overviewCards}
  />

  <TopicProcessSection
    eyebrow="When Extra Support Helps"
    title="Especially helpful when there is more history in the background"
    paragraphs={processParagraphs}
    steps={processSteps}
  />

  <LocalServiceArea serviceName="Prenatal Therapy" />

  <FaqSection
    faqs={faqItems}
    intro="Helpful answers about pregnancy support, location, and whether this service may fit."
  />

  <section class="py-16 xl:py-24 bg-white relative">
    <div class="max-w-[1200px] mx-auto px-5 md:px-10 xl:px-24">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2 class="text-3xl md:text-5xl font-bold text-[#1a1a1a] mb-6">Related Pages</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {relatedLinks.map((link) => (
          <a href={link.href} class="bg-[#fcfbf9] p-8 rounded-3xl border border-gray-100 hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            <h3 class="text-xl font-bold text-[#1a1a1a] mb-3">{link.title}</h3>
            <p class="text-gray-600 leading-relaxed">{link.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 md:py-28 bg-[#2f594f] relative overflow-hidden">
    <div class="max-w-[1000px] mx-auto px-5 md:px-10 text-center relative z-10">
      <h2 class="text-3xl md:text-5xl lg:text-6xl font-extrabold text-white mb-6 md:mb-8 tracking-tight">Support during pregnancy can make a real difference</h2>
      <a href="/contact" class="inline-flex items-center justify-center px-8 md:px-12 py-4 bg-[#fcc13e] text-[#1a1a1a] text-lg font-bold rounded-full hover:bg-white hover:text-[#2f594f] hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
        Contact Us
      </a>
    </div>
  </section>

  <Footer />
</Layout>
