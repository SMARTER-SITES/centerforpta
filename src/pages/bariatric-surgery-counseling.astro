---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import FaqSection from '../components/FaqSection.astro';
import LocalServiceArea from '../components/LocalServiceArea.astro';
import TopicHero from '../components/TopicHero.astro';
import TopicOverviewSection from '../components/TopicOverviewSection.astro';
import TopicProcessSection from '../components/TopicProcessSection.astro';
import { getServiceStructuredData } from '../utils/seo';

const stages = [
  {
    title: "Before Surgery",
    desc: "Process fear, expectations, readiness concerns, relationship dynamics, body image worries, and the lifestyle changes that surgery may require."
  },
  {
    title: "After Surgery",
    desc: "Adjust to emotional, behavioral, and identity changes after surgery, including shifts in eating patterns, self-image, and social or family roles."
  },
  {
    title: "When Motivation Feels Complicated",
    desc: "Make room for mixed feelings, setbacks, discouragement, or shame without losing sight of your longer-term goals."
  },
  {
    title: "Integrated Support",
    desc: "Therapy can complement medical care by helping with emotional regulation, coping skills, behavior change, and a more sustainable relationship with yourself."
  }
];

const relatedLinks = [
  {
    href: '/pre-surgical-psychological-evaluations',
    title: 'Pre-Surgical Psychological Evaluations',
    desc: 'Psychological clearance evaluations for bariatric surgery and other medical procedures.'
  },
  {
    href: '/weight-loss-counseling',
    title: 'Weight Loss Counseling',
    desc: 'Support for emotional eating, body image, motivation, and behavior change.'
  },
  {
    href: '/contact',
    title: 'Book a Consultation',
    desc: 'Reach out about bariatric counseling in Schaumburg or via telehealth in Illinois.'
  }
];

const signals = ['In-person in Schaumburg', 'Telehealth across Illinois', 'Pre-op and post-op emotional support'];

const careStyle = [
  {
    title: 'Warm and steady',
    desc: 'Supportive when surgery brings up mixed feelings, pressure, grief, or self-doubt.'
  },
  {
    title: 'Practical and emotionally aware',
    desc: 'Focused on what changes psychologically before and after surgery, not just medically.'
  },
  {
    title: 'Integrated perspective',
    desc: 'Useful when body image, motivation, routines, identity, and relationships are all shifting together.'
  }
];

const overviewParagraphs = [
  'Bariatric surgery can involve much more than a medical procedure. It can bring up fears, hope, grief, pressure, complicated expectations, and major identity questions before and after surgery.',
  'Counseling can help you prepare emotionally, strengthen coping skills, and navigate the practical and psychological changes that may come with the process.',
  'Clients who want bariatric surgery counseling near Schaumburg can meet in person, while telehealth makes this support available throughout Illinois.'
];

const processParagraphs = [
  'Some clients need a formal pre-surgical psychological evaluation for clearance. Others need therapy or supportive counseling before or after surgery. These are related but different services.',
  'If you are unsure which one fits your situation, reaching out first can help clarify whether you need an evaluation, ongoing counseling, or both.'
];

const processSteps = [
  {
    title: 'Prepare for the emotional shift',
    desc: 'Make room for expectations, anxiety, readiness questions, and the meaning surgery carries for you personally.'
  },
  {
    title: 'Adjust after surgery',
    desc: 'Process identity changes, eating-pattern changes, body image reactions, and relationship shifts as they unfold.'
  },
  {
    title: 'Stay connected to long-term goals',
    desc: 'Work through discouragement, shame, or setbacks without losing the bigger picture of your care.'
  }
];

const pageDescription =
  'Bariatric surgery counseling in Schaumburg, IL with telehealth across Illinois for emotional readiness, body image concerns, behavior change, post-op adjustment, and ongoing psychological support.';

const faqItems = [
  {
    question: 'What is bariatric surgery counseling?',
    answer:
      'Bariatric surgery counseling focuses on the emotional side of the process before and after surgery, including readiness concerns, expectations, identity shifts, body image, and long-term adjustment.'
  },
  {
    question: 'Do you provide bariatric counseling in Schaumburg, IL?',
    answer:
      'Yes. Sessions are available in person in Schaumburg and by telehealth for clients throughout Illinois.'
  },
  {
    question: 'How is counseling different from a pre-surgical psychological evaluation?',
    answer:
      'A pre-surgical evaluation is typically a formal assessment used for medical clearance. Counseling is ongoing therapeutic support and may happen before surgery, after surgery, or both.'
  }
];

const serviceStructuredData = getServiceStructuredData({
  name: 'Bariatric Surgery Counseling',
  description: pageDescription,
  path: '/bariatric-surgery-counseling/',
  serviceType: 'Bariatric Surgery Counseling'
});
---

<Layout
  title="Bariatric Surgery Counseling in Schaumburg, IL"
  description={pageDescription}
  faqItems={faqItems}
  structuredData={serviceStructuredData}
>
  <Navbar />
  <TopicHero
    title="Bariatric Surgery Counseling"
    accent="before and after major change"
    description="Emotional support before and after bariatric surgery for readiness, body image, identity changes, behavior change, and long-term adjustment."
    imageAlt="Therapy office prepared for supportive counseling"
    imageSrc="/images/bariatric-surgery-counseling.jpg"
    fitText="a space to work through readiness, adjustment, and the emotional impact of bariatric care"
    signals={signals}
    careStyle={careStyle}
  />

  <TopicOverviewSection
    eyebrow="Bariatric Care"
    title="Support for the emotional side of surgery"
    paragraphs={overviewParagraphs}
    cards={stages}
  />

  <TopicProcessSection
    eyebrow="Clarifying the Service"
    title="Counseling and evaluation are related, but not the same"
    paragraphs={processParagraphs}
    steps={processSteps}
  />

  <LocalServiceArea serviceName="Bariatric Surgery Counseling" />

  <FaqSection
    faqs={faqItems}
    intro="Quick answers about location, fit, and how this service differs from formal evaluations."
  />

  <section class="py-16 xl:py-24 bg-white relative">
    <div class="max-w-[1200px] mx-auto px-5 md:px-10 xl:px-24">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2 class="text-3xl md:text-5xl font-bold text-[#1a1a1a] mb-6">Related Pages</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {relatedLinks.map((link) => (
          <a href={link.href} class="bg-[#fcfbf9] p-8 rounded-3xl border border-gray-100 hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            <h3 class="text-xl font-bold text-[#1a1a1a] mb-3">{link.title}</h3>
            <p class="text-gray-600 leading-relaxed">{link.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 md:py-28 bg-[#2f594f] relative overflow-hidden">
    <div class="max-w-[1000px] mx-auto px-5 md:px-10 text-center relative z-10">
      <h2 class="text-3xl md:text-5xl lg:text-6xl font-extrabold text-white mb-6 md:mb-8 tracking-tight">Steady emotional support matters here too</h2>
      <a href="/contact" class="inline-flex items-center justify-center px-8 md:px-12 py-4 bg-[#fcc13e] text-[#1a1a1a] text-lg font-bold rounded-full hover:bg-white hover:text-[#2f594f] hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
        Contact Us
      </a>
    </div>
  </section>

  <Footer />
</Layout>
