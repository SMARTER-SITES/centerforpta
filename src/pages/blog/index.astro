---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const allPosts = Object.values(import.meta.glob('./*.md', { eager: true })) as Array<{
  frontmatter: {
    date: string;
    title: string;
    description?: string;
    image?: string;
  };
  url: string;
}>;

// Sort posts by date (newest first)
const sortedPosts = allPosts.sort((a, b) => {
  return new Date(b.frontmatter.date).valueOf() - new Date(a.frontmatter.date).valueOf();
});
---

<Layout
  title="Blog | Center for Psychological Treatment and Assessment"
  description="Mental health articles, therapy insights, and practical guidance from Dr. Jelena Djurovic and the Center for Psychological Treatment and Assessment."
>
  <Navbar />

  <!-- Hero Section -->
  <section class="relative pt-32 pb-16 md:pt-40 md:pb-24 bg-[#fcfbf9] overflow-hidden">
    <div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-[#e0eae5] rounded-full opacity-60 blur-3xl lg:blur-[80px]"></div>
    <div class="absolute bottom-[20%] right-[-10%] w-[30%] h-[50%] bg-[#fdf3df] rounded-full opacity-60 blur-3xl lg:blur-[80px]"></div>
    <div class="max-w-[1000px] mx-auto px-5 md:px-10 text-center relative z-10">
      <h1 class="text-4xl md:text-6xl xl:text-[72px] font-extrabold text-[#1a1a1a] leading-tight tracking-tight mb-8">
        Our Blog
      </h1>
      <p class="text-lg md:text-2xl text-gray-700 leading-relaxed max-w-3xl mx-auto">
        Insights, news, and helpful information from our team of psychological professionals.
      </p>
    </div>
  </section>

  <!-- Content Section -->
  <section class="py-16 xl:py-24 bg-white relative">
    <div class="max-w-[1200px] mx-auto px-5 md:px-10 xl:px-24">
      {sortedPosts.length === 0 ? (
        <div class="text-center py-20">
          <p class="text-xl text-gray-500 font-medium">No blog posts available yet. Check back soon!</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 xl:gap-10">
          {sortedPosts.map(post => (
            <a href={post.url} class="group flex flex-col h-full bg-white border border-gray-100 rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
              {post.frontmatter.image ? (
                <div class="h-48 xl:h-56 w-full overflow-hidden basis-auto flex-shrink-0">
                  <img src={post.frontmatter.image} alt={post.frontmatter.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                </div>
              ) : (
                <div class="h-48 xl:h-56 w-full bg-[#f3f0e9] flex items-center justify-center flex-shrink-0">
                  <svg class="w-12 h-12 text-[#d1cbb8]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path></svg>
                </div>
              )}
              <div class="flex flex-col flex-1 p-6 md:p-8">
                <p class="text-xs font-bold text-[#147b6a] uppercase tracking-wider mb-3">
                  {new Date(post.frontmatter.date).toLocaleDateString()}
                </p>
                <h3 class="text-xl font-bold text-[#1a1a1a] mb-3 group-hover:text-[#2f594f] transition-colors line-clamp-2">
                  {post.frontmatter.title}
                </h3>
                {post.frontmatter.description && (
                  <p class="text-sm text-gray-600 mb-6 line-clamp-3">
                    {post.frontmatter.description}
                  </p>
                )}
                <div class="mt-auto flex items-center gap-2 text-sm font-bold text-[#2f594f]">
                  Read more 
                  <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                </div>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <Footer />
</Layout>
