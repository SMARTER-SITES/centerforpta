---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import FaqSection from '../components/FaqSection.astro';
import LocalServiceArea from '../components/LocalServiceArea.astro';
import TopicHero from '../components/TopicHero.astro';
import TopicOverviewSection from '../components/TopicOverviewSection.astro';
import TopicProcessSection from '../components/TopicProcessSection.astro';
import AuthorBioBox from '../components/AuthorBioBox.astro';
import PageAddressCard from '../components/PageAddressCard.astro';
import { getServiceStructuredData } from '../utils/seo';

const supportAreas = [
  {
    title: "Mood Changes and Overwhelm",
    desc: "Support for postpartum depression, postpartum anxiety, irritability, tearfulness, racing thoughts, or the feeling that everything suddenly feels heavier than expected."
  },
  {
    title: "Identity and Relationship Shifts",
    desc: "Help processing the emotional changes that can come with becoming a parent, changes in partnership, role overload, and feeling unlike yourself."
  },
  {
    title: "Recovery and Adjustment",
    desc: "Space to talk through sleep disruption, stress, self-criticism, loss of routine, and the challenge of caring for yourself while caring for a baby."
  },
  {
    title: "Postnatal Emotional Support",
    desc: "Postnatal therapy can help when you need steady support after birth, whether symptoms are severe or you simply feel emotionally stretched thin."
  }
];

const relatedLinks = [
  {
    href: '/prenatal-therapy',
    title: 'Prenatal Therapy',
    desc: 'Support during pregnancy for anxiety, uncertainty, and transition stress.'
  },
  {
    href: '/womens-mental-health-therapy',
    title: "Women's Mental Health Therapy",
    desc: 'Broader support for reproductive concerns, body image, and life-stage challenges.'
  },
  {
    href: '/contact',
    title: 'Book a Consultation',
    desc: 'Ask about postpartum therapy in person or through telehealth in Illinois.'
  }
];

const signals = ['In-person in Schaumburg', 'Telehealth across Illinois', 'Postpartum and postnatal support'];
const featureCards = [
  {
    title: 'Local Care',
    desc: 'In-person postpartum therapy in Schaumburg with a private setting designed for new parents who need focused support.'
  },
  {
    title: 'Whole-Person Focus',
    desc: 'Addresses mood changes, identity disruption, relationship strain, and the gap between expectations and reality after birth.'
  },
  {
    title: 'Flexible Format',
    desc: 'Telehealth across Illinois so new parents can access support during naps, breaks, or whenever a session fits the day.'
  }
];

const careStyle = [
  {
    title: 'Warm and non-shaming',
    desc: 'Helpful when you feel like you should be handling things better. This is a space where difficulty is expected, not judged.'
  },
  {
    title: 'Emotionally practical',
    desc: 'Focused on day-to-day overwhelm, sleep disruption, relationship friction, and the pressure to appear like you are coping when you are not.'
  },
  {
    title: 'Built for early support',
    desc: 'You do not need to wait until things are severe. Reaching out when something feels off is often the most effective time to start.'
  }
];

const overviewParagraphs = [
  'This service is for new parents who are struggling more than they expected and need support that goes beyond being told it gets easier. Whether symptoms are intense or you simply feel off, both are valid reasons to reach out.',
  'The postpartum period can be deeply meaningful, but it can also be emotionally disorganizing. Many new parents feel ashamed when they are struggling because they think they should be coping better or feeling differently.',
  'Postpartum therapy creates space to talk honestly about what is happening while building practical and emotional support for this stage of life.'
];

const processParagraphs = [
  'Therapy can be helpful when symptoms are severe, but it can also be helpful much earlier, when you simply notice that you feel overwhelmed, disconnected, exhausted, or unlike yourself after birth.',
  'Support can focus on emotional stabilization, self-compassion, communication, realistic expectations, and restoring a stronger sense of self during a demanding stage.'
];

const processSteps = [
  {
    title: 'Talk honestly about what changed',
    desc: 'Make room for overwhelm, grief, anxiety, or disconnection without minimizing what the postpartum period can do.'
  },
  {
    title: 'Stabilize what feels shaky',
    desc: 'Support sleep-related stress, emotional reactivity, relationship strain, and the feeling of not quite being yourself.'
  },
  {
    title: 'Recover a steadier sense of self',
    desc: 'Build more realistic expectations and more support around the version of life you are actually living now.'
  }
];

const pageDescription =
  'Postpartum therapy in Schaumburg, IL with telehealth across Illinois for postpartum anxiety, postpartum depression, overwhelm, identity shifts, relationship stress, and postnatal emotional support.';

const faqItems = [
  {
    question: 'What can postpartum therapy help with?',
    answer:
      'Postpartum therapy can help with postpartum anxiety, postpartum depression, irritability, overwhelm, identity changes, relationship strain, sleep disruption, and the emotional adjustment after birth.'
  },
  {
    question: 'Do you offer postpartum therapy in Schaumburg, IL and online?',
    answer:
      'Yes. Sessions are available in person in Schaumburg, and telehealth is available for clients throughout Illinois.'
  },
  {
    question: 'How soon after birth can I start postpartum therapy?',
    answer:
      'There is no minimum waiting period. Some clients reach out within the first few weeks after birth, while others start later. The office in Schaumburg is accessible from Arlington Heights, Des Plaines, Rolling Meadows, and surrounding suburbs, and telehealth is available for anyone in Illinois.'
  },
  {
    question: 'Is postpartum therapy only for severe symptoms?',
    answer:
      'No. Therapy can be appropriate when symptoms are severe, but it can also be helpful much earlier if you feel emotionally stretched thin, unlike yourself, or overwhelmed after birth.'
  }
];

const serviceStructuredData = getServiceStructuredData({
  name: 'Postpartum Therapy',
  description: pageDescription,
  path: '/postpartum-therapy/',
  serviceType: 'Postpartum Therapy'
});
---

<Layout
  title="Postpartum Therapy in Schaumburg, IL"
  description={pageDescription}
  faqItems={faqItems}
  structuredData={serviceStructuredData}
>
  <Navbar />
  <TopicHero
    title="Postpartum Therapy"
    accent="when after birth feels harder than expected"
    description="Postnatal mental health support for postpartum anxiety, postpartum depression, overwhelm, identity changes, relationship stress, and emotional recovery after birth."
    imageAlt="Therapy office offering postpartum support"
    imageSrc="/images/postpartum-therapy.jpg"
    fitText="support after birth when overwhelm, anxiety, exhaustion, or disconnection start taking up too much space"
    fitDescription="This service is for new parents who are struggling more than they expected and need support that goes beyond being told it gets easier. Whether symptoms are intense or you simply feel off, both are valid reasons to reach out."
    signals={signals}
    careStyle={careStyle}
    featureCards={featureCards}
  />

  <TopicOverviewSection
    eyebrow="Postpartum Support"
    title="When the postpartum period feels emotionally heavier than expected"
    paragraphs={overviewParagraphs}
    cards={supportAreas}
  />

  <TopicProcessSection
    eyebrow="Early Support Matters"
    title="You do not need to wait for a crisis"
    paragraphs={processParagraphs}
    steps={processSteps}
  />

  <LocalServiceArea
    serviceName="Postpartum Therapy"
    title="Postpartum Therapy in Schaumburg and the Greater Northwest Suburbs"
    paragraphs={[
      'Dr. Jelena Djurovic offers postpartum therapy at her Schaumburg office, serving new parents from Arlington Heights, Des Plaines, Mount Prospect, Palatine, Hoffman Estates, and the surrounding area. Her experience with perinatal mental health means the work can begin quickly without spending sessions on background education.',
      'Telehealth is available statewide for Illinois residents, which many new parents prefer during the postpartum period. If you started with prenatal therapy and want to continue into postpartum care, that continuity is available and often beneficial.'
    ]}
  />

  <AuthorBioBox />
  <PageAddressCard />

  <FaqSection
    faqs={faqItems}
    intro="A few common questions about postpartum and postnatal support, location, and timing."
  />

  <section class="py-16 xl:py-24 bg-white relative">
    <div class="max-w-[1200px] mx-auto px-5 md:px-10 xl:px-24">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2 class="text-3xl md:text-5xl font-bold text-[#1a1a1a] mb-6">Related Pages</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {relatedLinks.map((link) => (
          <a href={link.href} class="bg-[#fcfbf9] p-8 rounded-3xl border border-gray-100 hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            <h3 class="text-xl font-bold text-[#1a1a1a] mb-3">{link.title}</h3>
            <p class="text-gray-600 leading-relaxed">{link.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 md:py-28 bg-[#2f594f] relative overflow-hidden">
    <div class="max-w-[1000px] mx-auto px-5 md:px-10 text-center relative z-10">
      <h2 class="text-3xl md:text-5xl lg:text-6xl font-extrabold text-white mb-6 md:mb-8 tracking-tight">Postpartum support is real support</h2>
      <a href="/contact" class="inline-flex items-center justify-center px-8 md:px-12 py-4 bg-[#fcc13e] text-[#1a1a1a] text-lg font-bold rounded-full hover:bg-white hover:text-[#2f594f] hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
        Contact Us
      </a>
    </div>
  </section>

  <Footer />
</Layout>
