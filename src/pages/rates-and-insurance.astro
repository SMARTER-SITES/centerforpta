---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const prices = [
  { service: "Individual therapy", details: "60 min (53 clinical min)", price: "$200" },
  { service: "Couples and Family therapy", details: "Per session", price: "$250" },
  { service: "Group therapy", details: "Per session", price: "Starting at $100" },
  { service: "Psychological Assessment", details: "Comprehensive evaluation", price: "Starting at $2,000" },
  { service: "Immigration Evaluations", details: "Detailed legal reporting", price: "Starting at $1,500" },
  { service: "Consultation and Supervision", details: "Professional coaching", price: "Call for pricing" }
];
---

<Layout
  title="Rates & Insurance | Center for Psychological Treatment and Assessment"
  description="View therapy, assessment, and immigration evaluation rates, plus accepted insurance plans including BCBS PPO, Aetna, and UnitedHealthcare."
>
  <Navbar />

  <!-- Hero Section -->
  <section class="relative pt-32 pb-16 md:pt-40 md:pb-24 bg-[#fcfbf9] overflow-hidden">
    <div class="absolute bottom-[-10%] left-[-10%] w-[50%] h-[50%] bg-[#e0eae5] rounded-full opacity-60 blur-3xl lg:blur-[80px]"></div>
    <div class="max-w-[1000px] mx-auto px-5 md:px-10 text-center relative z-10">
      <h1 class="text-4xl md:text-6xl xl:text-[72px] font-extrabold text-[#1a1a1a] leading-tight tracking-tight mb-8">
        Rates and Insurance
      </h1>
      <p class="text-lg md:text-2xl text-gray-700 leading-relaxed max-w-3xl mx-auto">
        Transparent pricing and flexible payment options to ensure you get the care you need.
      </p>
    </div>
  </section>

  <!-- Content Section -->
  <section class="py-16 xl:py-24 bg-white relative">
    <div class="max-w-[1200px] mx-auto px-5 md:px-10 xl:px-24">
      <div class="max-w-4xl mb-12">
        <p class="text-lg text-gray-700 leading-relaxed">
          We offer transparent rates for therapy, psychological assessment, immigration evaluations, and pre-surgical evaluations in Schaumburg, IL. We currently accept BCBS PPO, Aetna, and UnitedHealthcare, and we can provide superbills for out-of-network reimbursement when appropriate.
        </p>
      </div>
      
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 xl:gap-16">
        
        <!-- Insurance Left Column -->
        <div class="lg:col-span-1 space-y-8 text-center lg:text-left">
          <div class="bg-[#d1f3f1] rounded-[2rem] p-10 border border-[#b8d6c9] shadow-sm">
            <svg class="w-12 h-12 text-[#147b6a] mb-6 inline-block lg:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
            <h2 class="text-2xl font-extrabold text-[#147b6a] mb-4">Insurance Accepted</h2>
            <p class="text-lg text-[#0d5c4e] font-bold mb-4">We proudly accept:</p>
            <div class="space-y-3 mb-6">
              <div class="bg-white rounded-xl px-6 py-3 text-center shadow-sm font-bold text-gray-800 border border-gray-100">BCBS PPO</div>
              <div class="bg-white rounded-xl px-6 py-3 text-center shadow-sm font-bold text-gray-800 border border-gray-100">Aetna</div>
              <div class="bg-white rounded-xl px-6 py-3 text-center shadow-sm font-bold text-gray-800 border border-gray-100">UnitedHealthcare</div>
            </div>
            <hr class="border-[#b8d6c9] my-6" />
            <h3 class="font-bold text-[#147b6a] mb-2">Out of Network?</h3>
            <p class="text-sm md:text-base text-[#0d5c4e] leading-relaxed">
              We will gladly provide superbills for you to submit to your insurance if we are out of your network.
            </p>
          </div>
        </div>

        <!-- Pricing Cards Right Column -->
        <div class="lg:col-span-2">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 lg:gap-6">
            {prices.map(item => (
              <div class="bg-white rounded-2xl border border-gray-200 p-6 md:p-8 shadow-sm hover:shadow-lg transition-shadow duration-300 hover:border-[#2f594f]">
                <h3 class="text-xl font-bold text-[#1a1a1a] mb-2">{item.service}</h3>
                <p class="text-sm text-gray-500 font-medium mb-6 uppercase tracking-wider">{item.details}</p>
                <div class="flex items-end gap-1">
                  <p class="text-3xl lg:text-4xl font-extrabold text-[#2f594f]">{item.price}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>

    </div>
  </section>

  <!-- CTA section -->
  <section class="py-20 md:py-28 bg-[#2f594f] relative overflow-hidden">
    <div class="max-w-[1000px] mx-auto px-5 md:px-10 text-center relative z-10">
      <h2 class="text-3xl md:text-5xl lg:text-6xl font-extrabold text-white mb-6 md:mb-8 tracking-tight">Got questions?</h2>
      <a href="/contact" class="inline-flex items-center justify-center px-8 md:px-12 py-4 bg-[#fcc13e] text-[#1a1a1a] text-lg font-bold rounded-full hover:bg-white hover:text-[#2f594f] hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
        Contact Us
      </a>
    </div>
  </section>

  <Footer />
</Layout>
