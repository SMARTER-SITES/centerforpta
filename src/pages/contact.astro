---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { providerLicenseNumber } from '../utils/seo';
---

<Layout
  title="Contact Us | Center for Psychological Treatment and Assessment"
  description="Contact the Center for Psychological Treatment and Assessment in Schaumburg, IL by phone, text, email, or online form to schedule a consultation."
>
  <Navbar />

  <!-- Hero Section -->
  <section class="relative pt-32 pb-16 md:pt-40 md:pb-24 bg-[#fcfbf9] overflow-hidden">
    <div class="absolute top-[20%] left-[-10%] w-[40%] h-[60%] bg-[#e0eae5] rounded-full opacity-60 blur-3xl lg:blur-[80px]"></div>
    <div class="absolute bottom-[20%] right-[-10%] w-[30%] h-[50%] bg-[#fdf3df] rounded-full opacity-60 blur-3xl lg:blur-[80px]"></div>
    <div class="max-w-[1000px] mx-auto px-5 md:px-10 text-center relative z-10">
      <h1 class="text-4xl md:text-6xl xl:text-[72px] font-extrabold text-[#1a1a1a] leading-tight tracking-tight mb-8">
        Get In Touch
      </h1>
      <p class="text-lg md:text-2xl text-gray-700 leading-relaxed max-w-3xl mx-auto">
        We can't wait to hear from you! Reach out via phone, email, or through our contact form.
      </p>
    </div>
  </section>

  <!-- Content Section -->
  <section class="py-16 xl:py-24 bg-white relative">
    <div class="max-w-[1200px] mx-auto px-5 md:px-10 xl:px-24">
      <div class="flex flex-col lg:flex-row gap-12 xl:gap-20">
        
        <!-- Contact Info Cards -->
        <div class="lg:w-1/2 space-y-6">
          <div class="bg-[#fcfbf9] rounded-[2rem] p-8 md:p-10 border border-gray-100 flex items-start gap-6 hover:shadow-lg transition-shadow">
            <div class="w-14 h-14 bg-white rounded-full flex items-center justify-center shadow-sm text-[#147b6a] flex-shrink-0">
               <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
            </div>
            <div>
              <p class="text-sm text-gray-500 font-bold uppercase tracking-wider mb-2">Phone / Text</p>
              <a href="tel:+18472300045" class="block text-2xl md:text-3xl font-extrabold text-[#1a1a1a] hover:text-[#2f594f] transition-colors">(847) 230-0045</a>
              <p class="text-gray-600 mt-2 font-medium">Fax: (847) 874-6273</p>
              <p class="text-gray-600 mt-1 font-medium">Text: (847) 929-7040</p>
            </div>
          </div>

          <div class="bg-[#fcfbf9] rounded-[2rem] p-8 md:p-10 border border-gray-100 flex items-start gap-6 hover:shadow-lg transition-shadow">
            <div class="w-14 h-14 bg-white rounded-full flex items-center justify-center shadow-sm text-[#147b6a] flex-shrink-0">
               <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            </div>
            <div>
              <p class="text-sm text-gray-500 font-bold uppercase tracking-wider mb-2">Email</p>
              <a href="mailto:info@centerforpta.com" class="block text-xl md:text-2xl font-extrabold text-[#1a1a1a] hover:text-[#2f594f] transition-colors break-all">info@centerforpta.com</a>
            </div>
          </div>

          <div class="bg-[#d1f3f1] rounded-[2rem] p-8 md:p-10 border border-[#b8d6c9] flex items-start gap-6 shadow-sm">
            <div class="w-14 h-14 bg-white rounded-full flex items-center justify-center shadow-sm text-[#147b6a] flex-shrink-0">
               <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            </div>
            <div>
              <p class="text-sm text-[#147b6a] font-bold uppercase tracking-wider mb-2">Our Office</p>
              <p class="text-xl md:text-2xl font-extrabold text-[#1a1a1a] mb-2 leading-tight">1320 Tower Rd, Suite 156<br />Schaumburg, IL 60173</p>
              <p class="text-sm md:text-base font-semibold text-[#0d5c4e] uppercase tracking-[0.16em]">Illinois License #{providerLicenseNumber}</p>
            </div>
          </div>
        </div>

        <!-- Netlify Form -->
        <div class="lg:w-1/2">
          <div class="bg-white rounded-[2rem] p-8 md:p-12 shadow-[0_20px_60px_rgba(0,0,0,0.06)] border border-gray-100 h-full">
            <h2 class="text-3xl font-extrabold text-[#1a1a1a] mb-8">Send us a message</h2>
            <form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="flex flex-col gap-5">
              <p class="hidden">
                <label>Don’t fill this out if you're human: <input name="bot-field" /></label>
              </p>
              <div class="flex flex-col sm:flex-row gap-5">
                <input
                  type="text"
                  name="first-name"
                  placeholder="First Name *"
                  required
                  class="w-full bg-[#fcfbf9] border border-gray-200 h-14 rounded-2xl px-5 text-base text-black placeholder:text-gray-400 outline-none focus:ring-2 focus:ring-[#2f594f]/40 focus:border-[#2f594f] transition-all"
                />
                <input
                  type="text"
                  name="last-name"
                  placeholder="Last Name *"
                  required
                  class="w-full bg-[#fcfbf9] border border-gray-200 h-14 rounded-2xl px-5 text-base text-black placeholder:text-gray-400 outline-none focus:ring-2 focus:ring-[#2f594f]/40 focus:border-[#2f594f] transition-all"
                />
              </div>
              <input
                type="email"
                name="email"
                placeholder="Email Address *"
                required
                class="w-full bg-[#fcfbf9] border border-gray-200 h-14 rounded-2xl px-5 text-base text-black placeholder:text-gray-400 outline-none focus:ring-2 focus:ring-[#2f594f]/40 focus:border-[#2f594f] transition-all"
              />
              <textarea
                name="message"
                placeholder="How can we help you? *"
                required
                rows="6"
                class="w-full bg-[#fcfbf9] border border-gray-200 rounded-2xl px-5 py-4 text-base text-black placeholder:text-gray-400 outline-none focus:ring-2 focus:ring-[#2f594f]/40 focus:border-[#2f594f] transition-all resize-none"
              ></textarea>
              <button 
                type="submit" 
                class="h-14 mt-4 bg-[#2f594f] rounded-2xl text-lg font-bold text-white hover:bg-[#1f3f37] hover:shadow-xl hover:-translate-y-1 transition-all duration-300"
              >
                Send Message
              </button>
            </form>
          </div>
        </div>

      </div>
    </div>
  </section>

  <Footer />
</Layout>
