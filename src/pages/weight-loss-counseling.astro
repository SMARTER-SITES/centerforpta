---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const topics = [
  {
    title: "Emotional Eating Patterns",
    desc: "Understand how stress, loneliness, shame, or exhaustion may be shaping eating behaviors and making sustainable change harder."
  },
  {
    title: "Body Image and Motivation",
    desc: "Work through discouragement, comparison, and all-or-nothing thinking so that progress can feel more realistic and less punishing."
  },
  {
    title: "Behavior Change Support",
    desc: "Therapy can support the emotional side of consistency, setbacks, routines, and motivation while helping you build practical coping tools."
  },
  {
    title: "Long-Term Mental Health",
    desc: "The focus is not just on weight outcomes, but also on reducing shame, improving self-trust, and supporting healthier daily functioning."
  }
];

const relatedLinks = [
  {
    href: '/bariatric-surgery-counseling',
    title: 'Bariatric Surgery Counseling',
    desc: 'Emotional support before or after bariatric surgery and lifestyle adjustment.'
  },
  {
    href: '/pre-surgical-psychological-evaluations',
    title: 'Pre-Surgical Evaluations',
    desc: 'Psychological clearance evaluations for bariatric and other medical procedures.'
  },
  {
    href: '/contact',
    title: 'Book a Consultation',
    desc: 'Ask about counseling in Schaumburg or telehealth across Illinois.'
  }
];
---

<Layout
  title="Weight Loss Counseling in Illinois | Emotional Eating, Body Image, and Behavior Change"
  description="Weight loss counseling in Illinois for emotional eating, body image concerns, behavior change, motivation, and a healthier relationship with food and yourself."
>
  <Navbar />

  <section class="relative pt-32 pb-16 md:pt-40 md:pb-24 bg-[#fcfbf9] overflow-hidden">
    <div class="absolute top-[20%] right-[-10%] w-[40%] h-[60%] bg-[#fdf3df] rounded-full opacity-60 blur-3xl lg:blur-[80px]"></div>
    <div class="max-w-[1000px] mx-auto px-5 md:px-10 text-center relative z-10">
      <p class="text-[15px] xl:text-lg font-bold text-[#2f594f] uppercase tracking-widest mb-4">Specialized Therapy</p>
      <h1 class="text-4xl md:text-5xl xl:text-[64px] font-extrabold text-[#1a1a1a] leading-tight tracking-tight mb-8">
        Weight Loss Counseling in Illinois
      </h1>
      <p class="text-lg md:text-2xl text-gray-700 leading-relaxed max-w-3xl mx-auto">
        Counseling support for emotional eating, body image concerns, motivation, self-criticism, and the emotional ups and downs that often come with trying to make lasting health changes.
      </p>
    </div>
  </section>

  <section class="py-16 xl:py-24 bg-white relative">
    <div class="max-w-[1200px] mx-auto px-5 md:px-10 xl:px-24">
      <div class="max-w-4xl mx-auto text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-bold text-[#1a1a1a] mb-6">More Than Willpower</h2>
        <p class="text-lg text-gray-700 leading-relaxed mb-6">
          Many people already know what they are "supposed" to do, but insight alone does not always translate into change. Stress, shame, perfectionism, trauma history, and a difficult relationship with food or body image can make it hard to stay consistent even when motivation is strong.
        </p>
        <p class="text-lg text-gray-700 leading-relaxed">
          Weight loss counseling focuses on the emotional and psychological factors that affect behavior change so that progress can become more sustainable and less driven by guilt.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 xl:gap-8">
        {topics.map((item) => (
          <div class="bg-[#fcfbf9] p-8 rounded-3xl border border-gray-100 hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            <h3 class="text-2xl font-bold text-[#1a1a1a] mb-4">{item.title}</h3>
            <p class="text-gray-600 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 xl:py-24 bg-[#fcfbf9] relative">
    <div class="max-w-[1200px] mx-auto px-5 md:px-10 xl:px-24">
      <div class="bg-white p-8 md:p-12 rounded-[2rem] border border-gray-100">
        <h2 class="text-3xl md:text-4xl font-bold text-[#1a1a1a] mb-6">Support That Respects the Whole Person</h2>
        <p class="text-lg text-gray-700 leading-relaxed mb-6">
          This work is not about judgment, crash dieting, or simplistic advice. It is about understanding the role of thoughts, feelings, history, habits, and stress in the change process, then building a steadier and more compassionate approach.
        </p>
        <p class="text-lg text-gray-700 leading-relaxed">
          Therapy may be especially helpful when weight-related concerns overlap with anxiety, depression, body image distress, or pre- and post-bariatric care.
        </p>
      </div>
    </div>
  </section>

  <section class="py-16 xl:py-24 bg-white relative">
    <div class="max-w-[1200px] mx-auto px-5 md:px-10 xl:px-24">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2 class="text-3xl md:text-5xl font-bold text-[#1a1a1a] mb-6">Related Pages</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {relatedLinks.map((link) => (
          <a href={link.href} class="bg-[#fcfbf9] p-8 rounded-3xl border border-gray-100 hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            <h3 class="text-xl font-bold text-[#1a1a1a] mb-3">{link.title}</h3>
            <p class="text-gray-600 leading-relaxed">{link.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 md:py-28 bg-[#2f594f] relative overflow-hidden">
    <div class="max-w-[1000px] mx-auto px-5 md:px-10 text-center relative z-10">
      <h2 class="text-3xl md:text-5xl lg:text-6xl font-extrabold text-white mb-6 md:mb-8 tracking-tight">You deserve support that goes deeper than advice</h2>
      <a href="/contact" class="inline-flex items-center justify-center px-8 md:px-12 py-4 bg-[#fcc13e] text-[#1a1a1a] text-lg font-bold rounded-full hover:bg-white hover:text-[#2f594f] hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
        Contact Us
      </a>
    </div>
  </section>

  <Footer />
</Layout>
