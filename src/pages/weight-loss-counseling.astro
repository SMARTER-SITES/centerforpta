---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import FaqSection from '../components/FaqSection.astro';
import LocalServiceArea from '../components/LocalServiceArea.astro';
import TopicHero from '../components/TopicHero.astro';
import TopicOverviewSection from '../components/TopicOverviewSection.astro';
import TopicProcessSection from '../components/TopicProcessSection.astro';
import { getServiceStructuredData } from '../utils/seo';

const topics = [
  {
    title: "Emotional Eating Patterns",
    desc: "Understand how stress, loneliness, shame, or exhaustion may be shaping eating behaviors and making sustainable change harder."
  },
  {
    title: "Body Image and Motivation",
    desc: "Work through discouragement, comparison, and all-or-nothing thinking so that progress can feel more realistic and less punishing."
  },
  {
    title: "Behavior Change Support",
    desc: "Therapy can support the emotional side of consistency, setbacks, routines, and motivation while helping you build practical coping tools."
  },
  {
    title: "Long-Term Mental Health",
    desc: "The focus is not just on weight outcomes, but also on reducing shame, improving self-trust, and supporting healthier daily functioning."
  }
];

const relatedLinks = [
  {
    href: '/bariatric-surgery-counseling',
    title: 'Bariatric Surgery Counseling',
    desc: 'Emotional support before or after bariatric surgery and lifestyle adjustment.'
  },
  {
    href: '/pre-surgical-psychological-evaluations',
    title: 'Pre-Surgical Evaluations',
    desc: 'Psychological clearance evaluations for bariatric and other medical procedures.'
  },
  {
    href: '/contact',
    title: 'Book a Consultation',
    desc: 'Ask about counseling in Schaumburg or telehealth across Illinois.'
  }
];

const signals = ['In-person in Schaumburg', 'Telehealth across Illinois', 'Body image and emotional eating support'];

const careStyle = [
  {
    title: 'Warm and nonjudgmental',
    desc: 'Built for people who are tired of feeling shamed by weight-related struggles.'
  },
  {
    title: 'Behavior-aware',
    desc: 'Focused on what actually interrupts consistency, not just what sounds good on paper.'
  },
  {
    title: 'Whole-person perspective',
    desc: 'Useful when food, motivation, anxiety, body image, and self-worth are all tangled together.'
  }
];

const overviewParagraphs = [
  'Many people already know what they are supposed to do, but insight alone does not always translate into change. Stress, shame, perfectionism, trauma history, and a difficult relationship with food or body image can make it hard to stay consistent even when motivation is strong.',
  'Weight loss counseling focuses on the emotional and psychological factors that affect behavior change so that progress can become more sustainable and less driven by guilt.',
  'If you are searching for weight loss counseling near Schaumburg, care is available in person there and online for adults located anywhere in Illinois.'
];

const processParagraphs = [
  'This work is not about judgment, crash dieting, or simplistic advice. It is about understanding the role of thoughts, feelings, history, habits, and stress in the change process, then building a steadier and more compassionate approach.',
  'Therapy may be especially helpful when weight-related concerns overlap with anxiety, depression, body image distress, or pre- and post-bariatric care.'
];

const processSteps = [
  {
    title: 'Identify the emotional cycle',
    desc: 'Look at how stress, loneliness, shame, and all-or-nothing thinking shape eating and motivation.'
  },
  {
    title: 'Reduce shame and reactivity',
    desc: 'Create more breathing room between difficult feelings and impulsive or discouraging habits.'
  },
  {
    title: 'Support steadier change',
    desc: 'Build routines and coping strategies that are more realistic, more humane, and easier to maintain.'
  }
];

const pageDescription =
  'Weight loss counseling in Schaumburg, IL with telehealth across Illinois for emotional eating, body image concerns, behavior change, motivation, and a healthier relationship with food and yourself.';

const faqItems = [
  {
    question: 'What does weight loss counseling help with?',
    answer:
      'Weight loss counseling can help with emotional eating, shame, all-or-nothing thinking, motivation swings, body image concerns, and the emotional side of behavior change.'
  },
  {
    question: 'Is weight loss counseling available in Schaumburg and online in Illinois?',
    answer:
      'Yes. Clients can meet in person in Schaumburg, Illinois or by telehealth from anywhere in Illinois.'
  },
  {
    question: 'Is this the same as bariatric surgery counseling?',
    answer:
      'Not exactly. Weight loss counseling is broader and may focus on emotional eating, body image, and long-term behavior change. Bariatric surgery counseling is more specifically centered on pre-op and post-op adjustment.'
  }
];

const serviceStructuredData = getServiceStructuredData({
  name: 'Weight Loss Counseling',
  description: pageDescription,
  path: '/weight-loss-counseling/',
  serviceType: 'Weight Loss Counseling'
});
---

<Layout
  title="Weight Loss Counseling in Schaumburg, IL"
  description={pageDescription}
  faqItems={faqItems}
  structuredData={serviceStructuredData}
>
  <Navbar />
  <TopicHero
    title="Weight Loss Counseling"
    accent="that goes deeper than advice"
    description="Counseling support for emotional eating, body image concerns, motivation, self-criticism, and the emotional ups and downs that often come with trying to make lasting health changes."
    imageAlt="Comfortable therapy office in Schaumburg"
    imageSrc="/images/weight-loss-counseling.jpg"
    fitText="support for lasting change when stress, shame, and food are all part of the picture"
    signals={signals}
    careStyle={careStyle}
  />

  <TopicOverviewSection
    eyebrow="More Than Willpower"
    title="Why progress can feel harder than it looks"
    paragraphs={overviewParagraphs}
    cards={topics}
  />

  <TopicProcessSection
    eyebrow="How Counseling Helps"
    title="Support that respects the whole person"
    paragraphs={processParagraphs}
    steps={processSteps}
  />

  <LocalServiceArea serviceName="Weight Loss Counseling" />

  <FaqSection
    faqs={faqItems}
    intro="These answers help clarify what this counseling can cover and how to access it locally."
  />

  <section class="py-16 xl:py-24 bg-white relative">
    <div class="max-w-[1200px] mx-auto px-5 md:px-10 xl:px-24">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2 class="text-3xl md:text-5xl font-bold text-[#1a1a1a] mb-6">Related Pages</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {relatedLinks.map((link) => (
          <a href={link.href} class="bg-[#fcfbf9] p-8 rounded-3xl border border-gray-100 hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            <h3 class="text-xl font-bold text-[#1a1a1a] mb-3">{link.title}</h3>
            <p class="text-gray-600 leading-relaxed">{link.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 md:py-28 bg-[#2f594f] relative overflow-hidden">
    <div class="max-w-[1000px] mx-auto px-5 md:px-10 text-center relative z-10">
      <h2 class="text-3xl md:text-5xl lg:text-6xl font-extrabold text-white mb-6 md:mb-8 tracking-tight">You deserve support that goes deeper than advice</h2>
      <a href="/contact" class="inline-flex items-center justify-center px-8 md:px-12 py-4 bg-[#fcc13e] text-[#1a1a1a] text-lg font-bold rounded-full hover:bg-white hover:text-[#2f594f] hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
        Contact Us
      </a>
    </div>
  </section>

  <Footer />
</Layout>
