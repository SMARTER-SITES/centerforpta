---
const doctors = [
  { name: 'Dr. Halo Johny', experience: 'Experience 10 years' },
  { name: 'Dr. Halo Johny', experience: 'Experience 10 years' },
  { name: 'Dr. Halo Johny', experience: 'Experience 10 years' },
  { name: 'Dr. Halo Johny', experience: 'Experience 10 years' },
];
---

<section class="bg-cream py-14 xl:py-20">
  <div class="max-w-[1440px] mx-auto px-5 md:px-10 xl:px-24">

    <!-- Header -->
    <h2 class="text-2xl md:text-3xl xl:text-[40px] font-bold text-primary leading-normal">
      Get Treatment From Our Special Doctor
    </h2>

    <div class="mt-5 xl:mt-6 flex flex-wrap gap-3 xl:gap-6">
      <a href="#" class="flex h-12 xl:h-16 items-center justify-center px-8 xl:px-16 bg-accent rounded-full text-sm xl:text-base font-bold text-black">
        Click Here To See More
      </a>
      <a href="#" class="flex h-12 xl:h-16 items-center justify-center px-8 xl:px-16 bg-primary rounded-full text-sm xl:text-base font-bold text-white">
        Watch Videos
      </a>
    </div>

    <!-- Doctor cards: 1 → 2 → 4 columns -->
    <div class="mt-8 xl:mt-10 grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4 xl:gap-6">
      {doctors.map(({ name, experience }) => (
        <div class="relative bg-primary rounded-4xl h-[300px] md:h-[360px] xl:h-[433px] flex flex-col justify-end p-5 xl:p-6">
          <p class="text-xl xl:text-2xl font-bold text-white leading-normal">{name}</p>
          <p class="text-xs font-bold text-white mt-1">{experience}</p>
        </div>
      ))}
    </div>

  </div>
</section>
