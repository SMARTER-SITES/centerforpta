---
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  title?: string;
  intro?: string;
  faqs: FaqItem[];
}

const {
  title = 'Frequently Asked Questions',
  intro = 'Answers to a few common questions about this service.',
  faqs
} = Astro.props;
---

<section class="py-16 xl:py-24 bg-white relative">
  <div class="max-w-[1000px] mx-auto px-5 md:px-10">
    <div class="text-center max-w-3xl mx-auto mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-[#1a1a1a] mb-4">{title}</h2>
      <p class="text-lg text-gray-700">{intro}</p>
    </div>

    <div class="space-y-5">
      {faqs.map((faq) => (
        <div class="bg-[#fcfbf9] border border-gray-100 rounded-[2rem] p-7 md:p-8">
          <h3 class="text-xl md:text-2xl font-bold text-[#1a1a1a] mb-3">{faq.question}</h3>
          <p class="text-gray-700 leading-relaxed">{faq.answer}</p>
        </div>
      ))}
    </div>
  </div>
</section>
