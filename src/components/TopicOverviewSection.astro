---
interface CardItem {
  title: string;
  desc: string;
}

interface Props {
  eyebrow: string;
  title: string;
  paragraphs: string[];
  cards: CardItem[];
}

const { eyebrow, title, paragraphs, cards } = Astro.props;
---

<section class="py-16 xl:py-24 bg-white relative">
  <div class="max-w-[1200px] mx-auto px-5 md:px-10 xl:px-24">
    <div class="grid grid-cols-1 lg:grid-cols-[0.9fr_1.1fr] gap-10 xl:gap-16 items-start">
      <div class="lg:sticky lg:top-32">
        <p class="text-sm font-bold uppercase tracking-[0.18em] text-[#2f594f] mb-4">{eyebrow}</p>
        <h2 class="text-3xl md:text-4xl xl:text-[46px] font-bold text-[#1a1a1a] tracking-tight leading-tight mb-6">
          {title}
        </h2>
        <div class="space-y-6">
          {paragraphs.map((paragraph) => (
            <p class="text-lg text-gray-700 leading-relaxed">{paragraph}</p>
          ))}
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {cards.map((item, index) => (
          <div class:list={[
            'rounded-[2rem] border p-8 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg',
            index === 0 || index === cards.length - 1
              ? 'bg-[#fcfbf9] border-gray-100'
              : 'bg-[#f7faf8] border-[#dce9e4]'
          ]}>
            <div class="w-11 h-11 rounded-full bg-white border border-gray-200 flex items-center justify-center text-sm font-bold text-[#2f594f] mb-5">
              0{index + 1}
            </div>
            <h3 class="text-2xl font-bold text-[#1a1a1a] mb-4">{item.title}</h3>
            <p class="text-gray-600 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
