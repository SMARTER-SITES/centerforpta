---
const topics = [
  {
    title: "Women's Mental Health",
    description: 'Support for reproductive challenges, body image concerns, substance use concerns, and the emotional demands that can come with different stages of life.',
    href: '/womens-mental-health-therapy'
  },
  {
    title: 'Self-Compassion',
    description: "Help for harsh self-criticism, shame, perfectionism, burnout, and building a healthier relationship with yourself.",
    href: '/self-compassion-therapy'
  },
  {
    title: 'Bariatric Counseling',
    description: 'Emotional support before and after bariatric surgery for readiness, adjustment, body image, and long-term behavior change.',
    href: '/bariatric-surgery-counseling'
  },
  {
    title: 'Divorce Counseling',
    description: 'Therapy support before divorce and after divorce for grief, co-parenting stress, identity changes, and rebuilding stability.',
    href: '/divorce-counseling'
  }
];
---

<section class="bg-white py-16 xl:py-24">
  <div class="max-w-[1440px] mx-auto px-5 md:px-10 xl:px-24">
    <div class="text-center max-w-3xl mx-auto mb-14">
      <p class="text-[15px] xl:text-lg font-bold text-[#2f594f] uppercase tracking-widest mb-4">Featured Topics</p>
      <h2 class="text-4xl md:text-5xl xl:text-[56px] font-bold text-[#1a1a1a] mb-6 tracking-tight">
        Specialized Therapy Topics
      </h2>
      <p class="text-lg md:text-xl text-gray-600 leading-relaxed">
        Explore focused support for some of the most common therapy themes clients ask about, from women's mental health to self-compassion, bariatric counseling, and divorce-related transitions.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6 xl:gap-8">
      {topics.map((topic) => (
        <a href={topic.href} class="group flex flex-col h-full bg-[#fcfbf9] rounded-3xl border border-gray-100 p-8 shadow-sm hover:shadow-[0_18px_40px_rgba(0,0,0,0.08)] hover:-translate-y-1 transition-all duration-300">
          <div class="w-14 h-14 rounded-2xl bg-[#e8f2ee] text-[#2f594f] flex items-center justify-center mb-6 group-hover:bg-[#2f594f] group-hover:text-white transition-colors duration-300">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 6v12m6-6H6"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-[#1a1a1a] mb-4 leading-tight group-hover:text-[#2f594f] transition-colors">
            {topic.title}
          </h3>
          <p class="text-[15px] text-gray-600 leading-relaxed flex-1">
            {topic.description}
          </p>
          <div class="mt-6 inline-flex items-center gap-2 text-sm font-bold text-[#2f594f]">
            Learn more
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
            </svg>
          </div>
        </a>
      ))}
    </div>

    <div class="text-center mt-12">
      <a href="/therapy" class="inline-flex items-center justify-center px-8 py-4 bg-[#2f594f] text-white text-[15px] font-semibold rounded-full shadow-[0_8px_30px_rgba(47,89,79,0.25)] hover:shadow-[0_8px_30px_rgba(47,89,79,0.4)] hover:-translate-y-1 transition-all duration-300">
        View All Therapy Services
      </a>
    </div>
  </div>
</section>
