---
import { Image } from 'astro:assets';
import officeImg from '../assets/hero-office.png';

interface CareStyleItem {
  title: string;
  desc: string;
}

interface Props {
  title: string;
  accent: string;
  description: string;
  imageAlt: string;
  imageSrc?: string;
  fitText: string;
  fitDescription?: string;
  signals: string[];
  careStyle: CareStyleItem[];
  featureCards?: CareStyleItem[];
}

const defaultFeatureCards = [
  {
    title: 'Local Care',
    desc: 'In-person therapy in Schaumburg with a calm, private setting.'
  },
  {
    title: 'Whole-Person Focus',
    desc: 'Thoughtful support for overlapping emotional, relational, and life-stage stress.'
  },
  {
    title: 'Flexible Format',
    desc: 'Telehealth available across Illinois when that fits your life better.'
  }
];

const {
  title,
  accent,
  description,
  imageAlt,
  imageSrc,
  fitText,
  fitDescription = 'This page is designed for people who want support that feels thoughtful, grounded, and actually usable in daily life.',
  signals,
  careStyle,
  featureCards = defaultFeatureCards
} = Astro.props;
---

<section class="relative pt-28 md:pt-36 pb-16 md:pb-24 bg-[linear-gradient(180deg,#fcfbf9_0%,#f6f1ea_100%)] overflow-hidden">
  <div class="absolute top-[-10%] left-[-10%] w-[42%] h-[42%] bg-[#e0eae5] rounded-full opacity-70 blur-3xl lg:blur-[100px]"></div>
  <div class="absolute top-[18%] right-[-8%] w-[30%] h-[40%] bg-[#f4e8e1] rounded-full opacity-60 blur-3xl lg:blur-[100px]"></div>
  <div class="absolute bottom-[-10%] right-[10%] w-[28%] h-[28%] bg-[#fdf3df] rounded-full opacity-70 blur-3xl lg:blur-[100px]"></div>

  <div class="max-w-[1440px] mx-auto px-5 md:px-10 xl:px-24 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-[1.05fr_0.95fr] gap-12 xl:gap-20 items-center">
      <div>
        <div class="inline-flex items-center gap-3 px-4 py-2 rounded-full bg-white/85 backdrop-blur border border-white shadow-sm mb-7">
          <span class="h-2.5 w-2.5 rounded-full bg-[#2f594f]"></span>
          <span class="text-[11px] md:text-[13px] font-bold text-gray-600 uppercase tracking-[0.18em]">Specialized Therapy</span>
        </div>

        <h1 class="text-[42px] md:text-[58px] xl:text-[72px] font-extrabold text-[#1a1a1a] leading-[0.98] tracking-[-0.03em] max-w-4xl">
          {title}
          <span class="block text-[#2f594f] italic font-medium mt-2">{accent}</span>
        </h1>

        <p class="mt-8 text-lg md:text-2xl text-gray-700 leading-relaxed max-w-2xl">
          {description}
        </p>

        <div class="mt-7 flex flex-wrap gap-3">
          {signals.map((item) => (
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/85 border border-white shadow-sm text-sm font-semibold text-[#1a1a1a]">
              <span class="text-[#2f594f]">•</span>
              <span>{item}</span>
            </div>
          ))}
        </div>

        <div class="mt-10 flex flex-col sm:flex-row gap-4">
          <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 bg-[#2f594f] text-white text-[15px] font-semibold rounded-full shadow-[0_10px_30px_rgba(47,89,79,0.22)] hover:-translate-y-1 hover:shadow-[0_14px_34px_rgba(47,89,79,0.28)] transition-all duration-300">
            Schedule a Consultation
          </a>
          <a href="/rates-and-insurance" class="inline-flex items-center justify-center px-8 py-4 bg-white text-[#1a1a1a] border border-gray-200 text-[15px] font-semibold rounded-full hover:bg-[#faf8f4] hover:border-gray-300 transition-all duration-300">
            Rates and Insurance
          </a>
        </div>

        <div class="mt-10 grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-3xl">
          {featureCards.map((card) => (
            <div class="rounded-[1.75rem] bg-white/85 border border-white shadow-sm p-5">
              <p class="text-xs font-bold uppercase tracking-[0.18em] text-[#2f594f] mb-2">{card.title}</p>
              <p class="text-sm text-gray-700 leading-relaxed">{card.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="relative">
        <div class="relative bg-white/70 backdrop-blur-sm border border-white rounded-[2.25rem] p-4 md:p-5 shadow-[0_24px_70px_rgba(0,0,0,0.08)]">
          <div class="rounded-[1.9rem] overflow-hidden h-[320px] md:h-[460px]">
            {imageSrc ? (
              <img
                src={imageSrc}
                alt={imageAlt}
                class="w-full h-full object-cover"
                loading="eager"
              />
            ) : (
              <Image
                src={officeImg}
                alt={imageAlt}
                class="w-full h-full object-cover"
                format="webp"
                quality={78}
                widths={[640, 1200]}
                sizes="(max-width: 1024px) 100vw, 620px"
              />
            )}
          </div>

          <div class="grid grid-cols-1 md:grid-cols-[1fr_0.9fr] gap-4 mt-4">
            <div class="rounded-[1.5rem] bg-[#2f594f] text-white p-6 md:p-7">
              <p class="text-xs font-bold uppercase tracking-[0.18em] text-[#d7ebe5] mb-3">Good Fit If You Need</p>
              <p class="text-lg md:text-[22px] font-bold leading-snug">
                {fitText}
              </p>
              <p class="mt-4 text-sm md:text-[15px] leading-relaxed text-white/80">{fitDescription}</p>
            </div>

            <div class="rounded-[1.5rem] bg-[#f7faf8] border border-[#dce9e4] p-6 md:p-7">
              <p class="text-xs font-bold uppercase tracking-[0.18em] text-[#2f594f] mb-3">Care Style</p>
              <div class="space-y-4">
                {careStyle.map((item) => (
                  <div>
                    <p class="text-base font-bold text-[#1a1a1a]">{item.title}</p>
                    <p class="text-sm text-gray-600 leading-relaxed mt-1">{item.desc}</p>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
