---
import Navbar from './Navbar.astro';
import { Image } from 'astro:assets';
import heroOfficeImg from '../assets/hero-office.png';

---

<div class="relative min-h-screen bg-[#fcfbf9] overflow-hidden flex flex-col pt-24">
  <!-- Soft decorative gradient orbs for modern aesthetic (optimized for mobile scroll performance) -->
  <div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-[#e0eae5] rounded-full opacity-60 blur-3xl lg:blur-[80px]"></div>
  <div class="absolute top-[20%] right-[-10%] w-[40%] h-[60%] bg-[#fdf3df] rounded-full opacity-60 blur-3xl lg:blur-[80px]"></div>
  <div class="absolute bottom-[-20%] left-[20%] w-[30%] h-[30%] bg-[#f4e8e1] rounded-full opacity-60 blur-3xl lg:blur-[80px]"></div>

  <Navbar />

  <!-- Hero Content -->
  <main class="relative z-10 flex-1 flex flex-col justify-center max-w-[1440px] mx-auto px-5 md:px-10 xl:px-24 w-full pb-16 pt-8 lg:pt-0">
    <div class="flex flex-col lg:flex-row items-center justify-between gap-12 xl:gap-20 w-full">
      
      <!-- Left: Text content -->
      <div class="w-full lg:w-[50%] flex flex-col relative z-20">
        <div class="inline-flex items-center gap-2.5 px-4 py-2 rounded-full bg-white border border-gray-100 shadow-sm w-fit mb-8">
          <span class="relative flex h-2.5 w-2.5">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#2f594f] opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-[#2f594f]"></span>
          </span>
          <span class="text-[11px] md:text-[13px] font-bold text-gray-600 uppercase tracking-widest">Accepting New Patients</span>
        </div>

        <h1 class="text-[40px] md:text-[56px] xl:text-[68px] font-bold text-[#1a1a1a] leading-[1.05] tracking-[-0.02em]">
          Psychological Care<br />
          <span class="text-[#2f594f] italic font-medium relative inline-block">
            for Clarity and Healing
            <svg class="absolute w-full h-3 -bottom-1 left-0 text-[#fcc13e] opacity-50" viewBox="0 0 100 10" preserveAspectRatio="none">
              <path d="M0 5 Q 50 15 100 5" stroke="currentColor" stroke-width="4" fill="transparent" />
            </svg>
          </span>
        </h1>

        <p class="mt-8 text-lg md:text-xl text-gray-600 leading-relaxed max-w-[520px] font-normal">
          Therapy, psychological assessment, immigration evaluations, and pre-surgical evaluations in Schaumburg, IL.
        </p>

        <p class="mt-4 text-[15px] md:text-base text-gray-500 italic font-medium">
          Sessions available in English, Serbian, and Spanish.
        </p>

        <p class="mt-3 text-[14px] md:text-[15px] text-gray-500 font-medium max-w-[520px]">
          In-person in Schaumburg and available across Illinois via telehealth.
        </p>

        <!-- CTA Buttons -->
        <div class="mt-10 flex flex-col sm:flex-row items-start sm:items-center gap-4">
          <a href="/contact" class="w-full sm:w-auto flex items-center justify-center px-8 py-4 bg-[#2f594f] text-white text-[15px] font-semibold rounded-full shadow-[0_8px_30px_rgba(47,89,79,0.3)] hover:shadow-[0_8px_30px_rgba(47,89,79,0.5)] hover:-translate-y-1 transition-all duration-300">
            Schedule a Free Consultation
          </a>
          <a href="/therapy" class="w-full sm:w-auto flex items-center justify-center gap-2 px-8 py-4 bg-white text-[#1a1a1a] border border-gray-200 text-[15px] font-semibold rounded-full hover:bg-gray-50 hover:border-gray-300 transition-all duration-300">
            Explore Our Services
          </a>
        </div>

        <!-- Trust indicators -->
        <div class="mt-14 flex flex-col sm:flex-row items-start sm:items-center gap-5 xl:gap-8">
          <div class="flex items-center gap-3 w-[155px] xl:w-[165px]">
             <div class="text-2xl flex-shrink-0">🎓</div>
             <div class="flex flex-col">
               <span class="text-[17px] font-extrabold text-[#1a1a1a] tracking-tight">10+ Years</span>
               <span class="text-[11px] font-bold text-gray-500 uppercase tracking-widest mt-0.5">Experience</span>
             </div>
          </div>
          <div class="hidden sm:block w-px h-10 bg-gray-200"></div>
          <div class="flex items-center gap-3 w-[155px] xl:w-[165px]">
             <div class="text-2xl flex-shrink-0">🌍</div>
             <div class="flex flex-col">
               <span class="text-[17px] font-extrabold text-[#1a1a1a] tracking-tight">3 Languages</span>
               <span class="text-[11px] font-bold text-gray-500 uppercase tracking-widest mt-0.5 leading-tight">English, Serbian, Spanish</span>
             </div>
          </div>
          <div class="hidden sm:block w-px h-10 bg-gray-200"></div>
          <div class="flex items-center gap-3 w-[155px] xl:w-[165px]">
             <div class="text-2xl flex-shrink-0">📍</div>
             <div class="flex flex-col">
               <span class="text-[17px] font-extrabold text-[#1a1a1a] tracking-tight whitespace-nowrap">Schaumburg, IL</span>
               <span class="text-[11px] font-bold text-gray-500 uppercase tracking-widest mt-0.5 leading-tight">Serving Chicagoland & all of IL</span>
             </div>
          </div>
        </div>
      </div>

      <!-- Right: Premium Image Layout -->
      <div class="w-full lg:w-[45%] relative z-10 mt-10 lg:mt-0">
        <div class="relative w-full aspect-[4/5] rounded-[2rem] md:rounded-[3rem] overflow-hidden shadow-[0_30px_60px_rgba(0,0,0,0.12)] transform lg:rotate-2 hover:rotate-0 transition-all duration-500 group">
          <Image 
            src={heroOfficeImg} 
            alt="Modern therapy office" 
            class="w-full h-full object-cover scale-105 group-hover:scale-100 transition-all duration-700"
            loading="eager"
            fetchpriority="high"
            format="webp"
            quality={75}
            widths={[480, 800]}
            sizes="(max-width: 1024px) 100vw, 480px"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/30 via-transparent to-transparent opacity-80"></div>
        </div>
        
        <!-- Floating trust badge -->
        <div class="absolute -bottom-6 -left-6 md:bottom-10 md:-left-12 bg-white/90 backdrop-blur-md p-5 rounded-2xl shadow-2xl flex items-center gap-4 animate-float border border-white">
          <div class="w-12 h-12 rounded-full bg-[#fdf3df]/80 flex items-center justify-center flex-none">
            <svg class="w-6 h-6 text-[#d4af37]" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
            </svg>
          </div>
          <div>
            <p class="text-[15px] font-bold text-[#1a1a1a] leading-tight">Empathetic Care</p>
            <p class="text-xs font-semibold text-gray-500 mt-0.5">Focus on healing and growth</p>
          </div>
        </div>
      </div>

    </div>
  </main>
</div>
