---
interface StepItem {
  title: string;
  desc: string;
}

interface Props {
  eyebrow: string;
  title: string;
  paragraphs: string[];
  steps: StepItem[];
}

const { eyebrow, title, paragraphs, steps } = Astro.props;
---

<section class="py-16 xl:py-24 bg-[#fcfbf9] relative">
  <div class="max-w-[1200px] mx-auto px-5 md:px-10 xl:px-24">
    <div class="rounded-[2.5rem] bg-[#1f3f37] text-white overflow-hidden shadow-[0_24px_60px_rgba(31,63,55,0.18)]">
      <div class="grid grid-cols-1 lg:grid-cols-[0.9fr_1.1fr]">
        <div class="p-8 md:p-12 xl:p-16 border-b lg:border-b-0 lg:border-r border-white/10">
          <p class="text-sm font-bold uppercase tracking-[0.18em] text-[#cfe6df] mb-4">{eyebrow}</p>
          <h2 class="text-3xl md:text-4xl xl:text-[44px] font-bold tracking-tight leading-tight mb-6">{title}</h2>
          <div class="space-y-6">
            {paragraphs.map((paragraph) => (
              <p class="text-lg text-white/80 leading-relaxed">{paragraph}</p>
            ))}
          </div>
        </div>

        <div class="p-8 md:p-12 xl:p-16">
          <div class="space-y-8">
            {steps.map((step, index) => (
              <div class="flex gap-5 items-start">
                <div class="w-12 h-12 rounded-full bg-white/10 border border-white/15 flex items-center justify-center text-sm font-bold text-[#fcc13e] flex-none">
                  0{index + 1}
                </div>
                <div>
                  <h3 class="text-2xl font-bold mb-3">{step.title}</h3>
                  <p class="text-white/75 leading-relaxed">{step.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
